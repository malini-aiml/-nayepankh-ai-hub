<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NayePankh - AI Hub Mobile App</title>
    <style>
        :root {
            --primary-color: #ff6b6b;
            --secondary-color: #4ecdc4;
            --dark-color: #2f3e46;
            --light-color: #f7f9fa;
            --nav-bg: #ffffff;
        }

        body {
            font-family: '-apple-system', BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--light-color);
            color: var(--dark-color);
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* Mobile App Header */
        header {
            background-color: white;
            padding: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }

        header h1 {
            margin: 0;
            font-size: 20px;
            color: var(--primary-color);
            font-weight: 700;
        }

        .status-badge {
            background-color: #e8f5e9;
            color: #2e7d32;
            padding: 5px 10px;
            border-radius: 15px;
            font-weight: 600;
            font-size: 11px;
        }

        /* Multi-Page Sections */
        .app-screen {
            flex: 1;
            display: none;
            flex-direction: column;
            overflow-y: auto;
            padding: 15px;
            box-sizing: border-box;
            padding-bottom: 80px; /* Safe area for bottom nav */
        }

        .app-screen.active {
            display: flex;
        }

        /* Home Screen Styling */
        .welcome-card {
            background: linear-gradient(135deg, var(--primary-color), #ff8787);
            color: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
        }

        .welcome-card h2 { margin: 0 0 10px 0; font-size: 22px; }
        .welcome-card p { margin: 0; font-size: 14px; opacity: 0.9; line-height: 1.4; }

        .feature-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .feature-card {
            background: white;
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .feature-card:active { transform: scale(0.95); }
        .feature-card .icon { font-size: 28px; margin-bottom: 8px; }
        .feature-card h3 { margin: 0; font-size: 14px; color: var(--dark-color); }

        /* Chat Screen Styling */
        .chat-box {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 10px;
        }

        .message {
            max-width: 80%;
            padding: 10px 14px;
            border-radius: 15px;
            font-size: 14px;
            line-height: 1.4;
        }

        .bot-message { background-color: #e9ecef; align-self: flex-start; border-bottom-left-radius: 3px; }
        .user-message { background-color: var(--primary-color); color: white; align-self: flex-end; border-bottom-right-radius: 3px; }

        .suggestions { display: flex; gap: 8px; overflow-x: auto; padding: 5px 0; margin-bottom: 5px; }
        .chip { background: white; border: 1px solid #ddd; padding: 6px 12px; border-radius: 15px; font-size: 12px; white-space: nowrap; cursor: pointer; }

        .input-container { display: flex; gap: 8px; background: white; padding: 5px; border-radius: 10px; border: 1px solid #ddd; }
        .input-container input { flex: 1; border: none; padding: 10px; outline: none; font-size: 14px; }
        .input-container button { background: var(--primary-color); color: white; border: none; padding: 0 15px; border-radius: 8px; font-weight: 600; cursor: pointer; }

        /* Bottom Tab Navigation Bar */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60px;
            background-color: var(--nav-bg);
            border-top: 1px solid #eee;
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 100;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #888;
            font-size: 11px;
            text-decoration: none;
            cursor: pointer;
            width: 25%;
        }

        .nav-item.active {
            color: var(--primary-color);
            font-weight: bold;
        }

        .nav-icon {
            font-size: 20px;
            margin-bottom: 2px;
        }
    </style>
</head>
<body>

    <header>
        <h1>NayePankh AI</h1>
        <div class="status-badge">● Online</div>
    </header>

    <div id="homeScreen" class="app-screen active">
        <div class="welcome-card">
            <h2>Spreading Happiness ✨</h2>
            <p>Welcome to NayePankh Foundation's official AI-powered community app. Join hands to empower underprivileged lives.</p>
        </div>
        
        <h3 style="margin: 10px 0; font-size: 16px;">Quick Actions</h3>
        <div class="feature-grid">
            <div class="feature-card" onclick="switchTab('chat')">
                <div class="icon">🤖</div>
                <h3>AI Chat Support</h3>
            </div>
            <div class="feature-card" onclick="switchTab('volunteer')">
                <div class="icon">🤝</div>
                <h3>Volunteer Hub</h3>
            </div>
            <div class="feature-card" onclick="switchTab('about')">
                <div class="icon">ℹ️</div>
                <h3>Our Mission</h3>
            </div>
            <div class="feature-card" onclick="alert('Thank you for your heart to give! Integration coming soon.')">
                <div class="icon">❤️</div>
                <h3>Donate Now</h3>
            </div>
        </div>
    </div>

    <div id="chatScreen" class="app-screen">
        <div class="chat-box" id="chatBox">
            <div class="message bot-message">
                Hello! I am your AI Virtual Assistant. Ask me anything about NayePankh Foundation's internships, camps, or donation process!
            </div>
        </div>
        <div class="suggestions">
            <div class="chip" onclick="quickQuery('What internships do you offer?')">💼 Internships</div>
            <div class="chip" onclick="quickQuery('How can I volunteer?')">🤝 Volunteering</div>
        </div>
        <div class="input-container">
            <input type="text" id="userInput" placeholder="Ask AI Assistant..." onkeypress="if(event.key==='Enter') sendChat()">
            <button onclick="sendChat()">Send</button>
        </div>
    </div>

    <div id="volunteerScreen" class="app-screen">
        <h2 style="color: var(--primary-color); font-size: 18px; margin-top: 0;">Become a Change Maker</h2>
        <p style="font-size: 14px; line-height: 1.5; color: #555;">NayePankh Foundation connects youth with real-world social impact projects. Fill your detail below to let our AI scan and match you to a nearby campaign!</p>
        
        <div style="background: white; padding: 15px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
            <label style="font-size: 12px; font-weight: 600; color: #666;">Full Name</label>
            <input type="text" placeholder="Malini P J" style="width: 100%; padding: 10px; margin: 5px 0 15px 0; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box;">
            
            <label style="font-size: 12px; font-weight: 600; color: #666;">Domain of Interest</label>
            <select style="width: 100%; padding: 10px; margin: 5px 0 15px 0; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box;">
                <option>Mobile App / Web Development</option>
                <option>Social Media Marketing</option>
                <option>Teaching & Content Creation</option>
            </select>
            
            <button onclick="alert('AI Application Submitted Successfully!')" style="width: 100%; background: var(--primary-color); color: white; border: none; padding: 12px; border-radius: 6px; font-weight: bold; cursor: pointer;">Submit via AI Match</button>
        </div>
    </div>

    <div id="aboutScreen" class="app-screen">
        <h2 style="color: var(--primary-color); font-size: 18px; margin-top: 0;">About NayePankh</h2>
        <p style="font-size: 14px; line-height: 1.6; color: #444;">NayePankh Foundation is one of the leading NGO networks working towards providing education, food, and essential resources to underprivileged sectors of society.</p>
        <div style="background: #e0f7fa; color: #006064; padding: 15px; border-radius: 10px; font-size: 13px; line-height: 1.4; font-weight: 500;">
            💡 <strong>Tech for Good:</strong> This mobile dashboard demonstrates how automated AI intelligence can help NGOs scale up coordination by 10x!
        </div>
    </div>

    <nav class="bottom-nav">
        <div class="nav-item active" id="tab-home" onclick="switchTab('home')">
            <span class="nav-icon">🏠</span>
            <span>Home</span>
        </div>
        <div class="nav-item" id="tab-chat" onclick="switchTab('chat')">
            <span class="nav-icon">💬</span>
            <span>AI Chat</span>
        </div>
        <div class="nav-item" id="tab-volunteer" onclick="switchTab('volunteer')">
            <span class="nav-icon">🤝</span>
            <span>Volunteer</span>
        </div>
        <div class="nav-item" id="tab-about" onclick="switchTab('about')">
            <span class="nav-icon">ℹ️</span>
            <span>About</span>
        </div>
    </nav>

    <script>
        // Multi-Page Screen Switching Logic
        function switchTab(tabName) {
            // Hide all screens
            document.querySelectorAll('.app-screen').forEach(screen => screen.classList.remove('active'));
            // Remove active style from all navigation tabs
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            
            // Show selected screen and highlight tab
            if(tabName === 'home') {
                document.getElementById('homeScreen').classList.add('active');
                document.getElementById('tab-home').classList.add('active');
            } else if(tabName === 'chat') {
                document.getElementById('chatScreen').classList.add('active');
                document.getElementById('tab-chat').classList.add('active');
            } else if(tabName === 'volunteer') {
                document.getElementById('volunteerScreen').classList.add('active');
                document.getElementById('tab-volunteer').classList.add('active');
            } else if(tabName === 'about') {
                document.getElementById('aboutScreen').classList.add('active');
                document.getElementById('tab-about').classList.add('active');
            }
        }

        // Chat Engine Logic
        const chatBox = document.getElementById('chatBox');
        const userInput = document.getElementById('userInput');

        const responses = {
            "internship": "NayePankh offers internships for students in Web/Mobile App Development, Content Writing, and Design. Apply via Internshala to get industry-ready experience and certifications!",
            "volunteer": "You can volunteer virtually or on-field. Use our app's 'Volunteer' tab to submit your profile directly for AI matching!",
            "hello": "Hi! Welcome to NayePankh AI Hub. Explore our tabs to join our mission.",
            "hi": "Hello! How can I assist your journey with NayePankh today?"
        };

        function sendChat() {
            const text = userInput.value.trim();
            if(!text) return;

            appendMsg(text, 'user-message');
            userInput.value = '';

            setTimeout(() => {
                let reply = "Thank you for reaching out! I'm scanning our directory. For official inquiries, write to contact@nayepankhfoundation.org.";
                const query = text.toLowerCase();
                
                for(let key in responses) {
                    if(query.includes(key)) {
                        reply = responses[key];
                        break;
                    }
                }
                appendMsg(reply, 'bot-message');
            }, 500);
        }

        function appendMsg(text, className) {
            const div = document.createElement('div');
            div.className = `message ${className}`;
            div.innerText = text;
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function quickQuery(text) {
            userInput.value = text;
            sendChat();
        }
    </script>
</body>
</html>

